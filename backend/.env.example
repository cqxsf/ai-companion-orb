# Database
DATABASE_URL=postgresql+asyncpg://orb:orb_password@localhost:5432/orb_db
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM providers
DASHSCOPE_API_KEY=your-dashscope-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Push notifications (JPush)
JPUSH_APP_KEY=your-jpush-app-key
JPUSH_MASTER_SECRET=your-jpush-master-secret

# Encryption (AES-256 — must be exactly 32 bytes base64-encoded)
ENCRYPTION_KEY=your-32-byte-base64-encoded-encryption-key=

# OTA
OTA_SERVER_URL=https://ota.example.com

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# LLM context
LLM_CONTEXT_WINDOW=20

# Speech services
COSYVOICE_API_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/tts
PARAFORMER_API_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/asr
